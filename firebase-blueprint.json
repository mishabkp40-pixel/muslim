{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user information and preferences.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The unique identifier for the user." },
        "displayName": { "type": "string", "description": "The user's display name." },
        "email": { "type": "string", "format": "email", "description": "The user's email address." },
        "photoURL": { "type": "string", "description": "The user's profile picture URL." },
        "phoneNumber": { "type": "string", "description": "The user's mobile number." },
        "role": { "type": "string", "enum": ["user", "admin"], "description": "The user's role in the application." },
        "subscriptionStatus": { "type": "string", "enum": ["free", "pro"], "description": "The user's current subscription level." },
        "subscriptionId": { "type": "string", "description": "The Stripe subscription ID." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the profile was created." }
      },
      "required": ["uid", "role"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Collection of user profiles."
    }
  }
}
